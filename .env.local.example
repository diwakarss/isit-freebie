# AWS Bedrock credentials (auto-detected from AWS credential chain if not set)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Optional: override Bedrock model (defaults to Claude Sonnet 4.5)
# BEDROCK_MODEL=anthropic.claude-sonnet-4-5-20250929-v1:0

# Share URL signing secret (any random 32+ char string)
SHARE_SECRET=any-random-string-32-chars-minimum
